{
  "name": "mmr-electron-gui",
  "description": "GUI for Majora's Mask Randomizer",
  "version": "1.16.0-12",
  "homepage": "https://www.mmrandomizer.com",
  "author": "ZeldaSpeedRuns <zsrstaff@gmail.com>",
  "main": "electron/dist/main.js",
  "scripts": {
    "ng": "ng",
    "test": "ng test",
    "lint": "ng lint",
    "ng-dev": "ng serve --configuration hmr",
    "ng-prod": "ng build --configuration production --base-href ./",
    "ng-release": "ng build --base-href ./",
    "electron-compile": "tsc --p electron",
    "electron-dev": "electron .",
    "electron-release": "electron . release",
    "pack": "tsc --p electron && electron-builder --dir",
    "dist": "tsc --p electron && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mmrandomizer.electrongui",
    "productName": "Majora's Mask Randomizer",
    "copyright": "Copyright © 2025 ${author}",
    "asar": false,
    "directories": {
      "output": "installer"
    },
    "files": [
      "**/*",
      "!src/*",
      "!bin/*",
      "!obj/*",
      "!e2e/*",
      "!webTest/*",
      "!dist/index.json",
      "!electron/src/*.ts",
      "!electron/tsconfig.json",
      "!electron/dist/index.json",
      "!electron/dist/*.map",
      "!*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj,bat,njsproj,md}",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj,bat,njsproj,md}",
      "!.editorconfig",
      "!angular.json",
      "!tsconfig.json",
      "!run.js",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes,.bat,.sln,.njsproj,.md}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}",
      "python/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32",
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false,
      "allowToChangeInstallationDirectory": false,
      "menuCategory": true
    },
    "linux": {
      "target": "tar.gz",
      "executableName": "mm-randomizer-gui"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  },
  "engines": {
    "node": ">=18.19.1 <=24"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "electron-window-state": "5.0.3",
    "post-robot": "https://github.com/dragonbane0/post-robot/tarball/dad59c1c0f6266d0dd4bd35e0fb7137d45c6c773",
    "tree-kill": "1.2.2",
    "tslib": "^2.6"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19",
    "@angular-eslint/builder": "^19",
    "@angular-eslint/eslint-plugin": "^19",
    "@angular-eslint/eslint-plugin-template": "^19",
    "@angular-eslint/schematics": "^19",
    "@angular-eslint/template-parser": "^19",
    "@angular/animations": "^19",
    "@angular/cdk": "^19",
    "@angular/cli": "^19",
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/forms": "^19",
    "@angular/language-service": "^19",
    "@angular/material": "^19",
    "@angular/platform-browser": "^19",
    "@angular/platform-browser-dynamic": "^19",
    "@angular/router": "^19",
    "@ng-web-apis/common": "^4.12.0",

    "@fortawesome/fontawesome-free": "6.7.2",
    "@nebular/eva-icons": "^15",
    "@nebular/theme": "^15",
    "@types/jasmine": "3.6.0",
    "@types/jasminewd2": "2.0.6",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "zsr-dual-listbox": "^9.0.1",
    "angular-file": "^4.0.2",
    "browserslist": "4.21.11",
    "core-js": "3.25.5",
    "crc": "3.8.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^8.28.0",
    "eva-icons": "1.1.3",
    "hammerjs": "2.0.8",
    "intl": "1.2.5",
    "ionicons": "4.6.4-1",
    "jasmine-core": "3.8.0",
    "jasmine-spec-reporter": "5.0.0",
    "jquery": "^3",
    "karma": "6.4.1",
    "karma-chrome-launcher": "3.1.0",
    "karma-coverage-istanbul-reporter": "2.0.5",
    "karma-jasmine": "4.0.0",
    "karma-jasmine-html-reporter": "1.5.0",
    "ngx-color-picker": "^15.0.0",
    "normalize.css": "6.0.0",
    "pace-js": "1.2.4",

    "roboto-fontface": "0.10.0",
    "rxjs": "^7.8.0",
    "sass": "1.90.0",
    "socicon": "3.0.5",
    "tcp-ping": "0.1.1",
    "ts-node": "7.0.1",
    "typescript": "^5.6",
    "zone.js": "~0.15.0"
  }
}
